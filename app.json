{
    "expo": {
        "name": "YOKOKart",
        "slug": "yokokart",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./assets/icon.png",
        "userInterfaceStyle": "light",
        "newArchEnabled": true,
        "splash": {
            "resizeMode": "contain",
            "backgroundColor": "#1D9E75"
        },
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.yokokart.app"
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#1D9E75"
            },
            "package": "com.yokokart.app",
            "permissions": [
                "android.permission.ACCESS_FINE_LOCATION",
                "android.permission.ACCESS_COARSE_LOCATION",
                "android.permission.CAMERA",
                "android.permission.READ_EXTERNAL_STORAGE",
                "android.permission.WRITE_EXTERNAL_STORAGE",
                "android.permission.VIBRATE",
                "android.permission.RECEIVE_BOOT_COMPLETED"
            ]
        },
        "plugins": [
            [
                "expo-location",
                {
                    "locationAlwaysAndWhenInUsePermission": "YOKOKart needs location to find nearest mart."
                }
            ],
            [
                "expo-camera",
                {
                    "cameraPermission": "YOKOKart needs camera for KYC verification."
                }
            ],
            [
                "expo-image-picker",
                {
                    "photosPermission": "YOKOKart needs photo access for KYC documents."
                }
            ],
            [
                "expo-notifications",
                {
                    "icon": "./assets/notification-icon.png",
                    "color": "#1D9E75",
                    "defaultChannel": "default"
                }
            ]
        ],
        "updates": {
            "url": "https://storage.googleapis.com/ksmcm-media/updates/android/latest.json"
        },
        "runtimeVersion": "1.0.0",
        "extra": {
            "eas": {
                "projectId": "your-eas-project-id"
            }
        }
    }
}